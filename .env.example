# Copia este archivo a ".env" y ajusta los valores según tu entorno.

# Clave secreta de Django (cámbiala en producción)
SECRET_KEY=django-insecure-cambia-esta-clave-en-produccion

# Modo depuración (True para desarrollo, False para producción)
DEBUG=True

# Hosts permitidos separados por comas
ALLOWED_HOSTS=localhost,127.0.0.1

# ====== Base de datos ======
# Usa "sqlite" (por defecto) o "postgresql"
DB_ENGINE=sqlite

# Configuración para PostgreSQL (solo si DB_ENGINE=postgresql)
DB_NAME=celulares_erp
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
